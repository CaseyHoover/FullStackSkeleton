{
  "name": "FullStackSkeleton",
  "dockerComposeFile": "docker-compose.yaml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "remoteUser": "root",
  "forwardPorts": [3000, 4000, 5555],
  "onCreateCommand": "cp /tmp/.host-gitconfig /root/.gitconfig 2>/dev/null; git config --global --add safe.directory /workspace && gh auth setup-git 2>/dev/null; bash /workspace/.devcontainer/setup-env.sh && pnpm install && pnpm db:generate && pnpm build ",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "chat.disableAIFeatures": true
      },
      "extensions": [
        "Anthropic.claude-code",
        "dbaeumer.vscode-eslint",
        "eamodio.gitlens",
        "esbenp.prettier-vscode",
        "GitHub.vscode-pull-request-github",
        "Prisma.prisma",
        "bradlc.vscode-tailwindcss",
        "github.vscode-github-actions",
        "mutantdino.resourcemonitor",
        "ms-azuretools.vscode-containers"
      ]
    }
  }
}
