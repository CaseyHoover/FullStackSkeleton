{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "noEmit": true,
    "jsx": "react-jsx",
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@skeleton/api-client": ["../../packages/api-client/src/index.ts"],
      "@skeleton/shared": ["../../packages/shared/src/index.ts"],
      "@skeleton/shared/*": ["../../packages/shared/src/*"],
      "@skeleton/auth": ["../../packages/auth/src/index.ts"],
      "@skeleton/auth/client": ["../../packages/auth/src/client.ts"],
      "@skeleton/auth/next": ["../../packages/auth/src/next.ts"],
      "@skeleton/auth/*": ["../../packages/auth/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
