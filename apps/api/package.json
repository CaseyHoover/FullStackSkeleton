{
  "name": "@skeleton/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env.local src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "jest --coverage"
  },
  "dependencies": {
    "@skeleton/auth": "workspace:*",
    "@skeleton/db": "workspace:*",
    "@prisma/client": "^6.6.0",
    "@skeleton/shared": "workspace:*",
    "@hono/node-server": "^1.14.0",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.2.4",
    "hono": "^4.7.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5"
  }
}
