{
  "name": "@skeleton/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch --env-file=.env.local src/index.ts",
    "build": "tsup src/index.ts --format esm",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest run --project api",
    "test:integration": "vitest run --project api:integration"
  },
  "dependencies": {
    "@hono/node-server": "~2.0.8",
    "@hono/swagger-ui": "~0.6.1",
    "@hono/zod-openapi": "~1.4.0",
    "@prisma/client": "~7.8.0",
    "@skeleton/auth": "workspace:*",
    "@skeleton/db": "workspace:*",
    "@skeleton/shared": "workspace:*",
    "hono": "~4.12.27",
    "zod": "~4.4.3"
  },
  "devDependencies": {
    "@types/node": "~26.1.0",
    "@vitest/ui": "~4.1.9",
    "better-auth": "~1.6.23",
    "tsup": "~8.5.1",
    "tsx": "~4.23.0",
    "typescript": "~6.0.3",
    "vitest": "~4.1.9"
  }
}
