{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env.local"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true,
      "interruptible": true,
      "dependsOn": ["^db:generate"]
    },
    "build": {
      "dependsOn": ["^build", "^db:generate"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "db:generate": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "codegen:openapi": {
      "dependsOn": ["@skeleton/api#build"],
      "outputs": ["packages/api-spec/openapi.yaml"]
    },
    "codegen:swift": {
      "dependsOn": ["codegen:openapi"],
      "outputs": ["apps/ios/HealthDash/Generated/**"]
    }
  }
}
