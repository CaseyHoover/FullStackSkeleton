{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env.local"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true,
      "interruptible": true,
      "dependsOn": ["^db:generate"],
      "env": ["DATABASE_URL"]
    },
    "build": {
      "dependsOn": ["^build", "^db:generate"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "test:integration": {
      "cache": false,
      "dependsOn": ["^db:generate"],
      "env": ["DATABASE_URL"]
    },
    "//#test:ui": {
      "cache": false,
      "persistent": true,
      "interruptible": true,
      "env": ["DATABASE_URL"]
    },
    "db:generate": {
      "cache": false
    },
    "db:push": {
      "cache": false,
      "env": ["DATABASE_URL"]
    },
    "codegen:openapi": {
      "dependsOn": ["@skeleton/api#build"],
      "outputs": ["packages/api-spec/openapi.yaml"]
    },
    "codegen:swift": {
      "dependsOn": ["codegen:openapi"],
      "outputs": ["apps/ios/FullStackSkeleton/Generated/**"]
    }
  }
}
